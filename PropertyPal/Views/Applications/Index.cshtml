@model IEnumerable<PropertyPal.Api.Models.Application>
@{ ViewData["Title"] = "Applications"; string S(int x)=>x switch{0=>"Application",1=>"Screening",2=>"Approved",3=>"Rejected",_=>"Unknown"}; }
<h1>Tenant Applications</h1>
<table class="table table-striped"><thead><tr><th>Unit</th><th>Property</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead><tbody>
@foreach(var a in Model){<tr><td>@a.Unit.UnitNumber</td><td>@a.Unit.Property.Name</td><td>@S(a.Status)</td><td>@a.CreatedAt.ToShortDateString()</td><td>
 <form method="post" asp-action="SetStatus" class="d-inline"><input type="hidden" name="id" value="@a.ApplicationId"/><input type="hidden" name="status" value="1"/><button class="btn btn-sm btn-secondary">Screening</button></form>
 <form method="post" asp-action="SetStatus" class="d-inline"><input type="hidden" name="id" value="@a.ApplicationId"/><input type="hidden" name="status" value="2"/><button class="btn btn-sm btn-success">Approve & Lease</button></form>
 <form method="post" asp-action="SetStatus" class="d-inline"><input type="hidden" name="id" value="@a.ApplicationId"/><input type="hidden" name="status" value="3"/><button class="btn btn-sm btn-danger">Reject</button></form>
</td></tr>}
</tbody></table>
