@model IEnumerable<PropertyPal.Api.Models.MaintenanceRequest>
@{ ViewData["Title"] = "My Requests"; string S(int x)=>x switch{0=>"Submitted",1=>"Assigned",2=>"In Progress",3=>"Resolved",4=>"Closed",_=>"Unknown"}; }
<h1>Track Request Status</h1>
<table class="table table-striped"><thead><tr><th>Ticket</th><th>Title</th><th>Unit</th><th>Status</th><th>Created</th></tr></thead><tbody>
@foreach(var r in Model){<tr><td>@r.TicketNumber</td><td>@r.Title</td><td>@r.Unit.UnitNumber</td><td>@S(r.Status)</td><td>@r.CreatedAt</td></tr>}
</tbody></table>
