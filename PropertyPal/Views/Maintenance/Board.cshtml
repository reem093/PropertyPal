@model IEnumerable<PropertyPal.Api.Models.MaintenanceRequest>
@{ ViewData["Title"] = "Live Maintenance Board"; string S(int x)=>x switch{0=>"Submitted",1=>"Assigned",2=>"In Progress",3=>"Resolved",4=>"Closed",_=>"Unknown"}; }
<h1>Live Maintenance Board</h1>
<div id="liveAlert" class="alert alert-info d-none"></div>
<table class="table table-striped"><thead><tr><th>Ticket</th><th>Title</th><th>Unit</th><th>Status</th><th>Created</th></tr></thead><tbody>
@foreach(var r in Model){<tr><td>@r.TicketNumber</td><td>@r.Title</td><td>@r.Unit.UnitNumber</td><td>@S(r.Status)</td><td>@r.CreatedAt</td></tr>}
</tbody></table>
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
<script>
const connection = new signalR.HubConnectionBuilder().withUrl('/maintenanceHub').build();
connection.on('MaintenanceChanged', (ticket, status) => {
 const box = document.getElementById('liveAlert'); box.classList.remove('d-none'); box.innerText = `Maintenance ${ticket} changed to ${status}. Refresh to see full table.`;
});
connection.start();
</script>
