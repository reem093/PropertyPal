@model PropertyPal.Api.Models.Unit
@{ ViewData["Title"] = "Add Unit"; }
<h1>Add Unit</h1>
<form method="post">
 <div class="mb-3"><label>Property</label><select asp-for="PropertyId" class="form-select" asp-items="@(new SelectList(ViewBag.Properties, "PropertyId", "Name"))"></select></div>
 <div class="mb-3"><label>Unit Number</label><input asp-for="UnitNumber" class="form-control" /></div>
 <div class="mb-3"><label>Rent</label><input asp-for="RentAmount" class="form-control" /></div>
 <div class="mb-3"><label>Size</label><input asp-for="Size" class="form-control" /></div>
 <div class="mb-3"><label>Type</label><select asp-for="Type" class="form-select"><option value="1">Residential</option><option value="2">Commercial</option></select></div>
 <div class="mb-3"><label>Status</label><select asp-for="Status" class="form-select"><option value="0">Available</option><option value="1">Occupied</option></select></div>
 <button class="btn btn-primary">Save</button>
</form>
