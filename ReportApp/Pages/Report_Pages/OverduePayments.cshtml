@page
@model ReportApp.Pages.Report_Pages.OverduePaymentsModel
@using System.Reflection
@{
	ViewData["Title"] = "Overdue Payments Summary";
	PropertyInfo[] properties = typeof(OverduePaymentsDTO).GetProperties();
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
		<div>
			<h2 class="text-dark mb-1">Overdue Payments Summary</h2>
			<p class="text-muted mb-0">Financial monitoring tool for identifying delinquent rental accounts and collection age tracking.</p>
		</div>
		<a href="/Report_Pages/Index" class="btn btn-outline-secondary fw-bold px-3 py-2">
			&larr; Back to Portal
		</a>
	</div>

	<div class="card shadow-sm border-danger">
		<div class="card-header bg-danger py-3">
			<h5 class="mb-0 text-white">Outsanding Balances (@Model.OverduePayments.Count Accounts)</h5>
		</div>
		<div class="card-body p-4">
			@if (Model.OverduePayments == null || !Model.OverduePayments.Any())
			{
				<div class="text-center text-muted py-3">No delinquent account data stream found.</div>
			}
			else
			{
				<input type="text" id="paymentsSearch" placeholder="Search accounts by tenant, building, unit, or status..." class="form-control mb-3 shadow-sm"/>

				<div class="table-responsive">
					<table class="table table-striped table-hover mb-0 align-middle border" id="paymentsTable">
						<thead class="table-dark">
							<tr>
								@foreach (PropertyInfo prop in properties)
								{
									<th>
										@System.Text.RegularExpressions.Regex.Replace(prop.Name, "([a-z])([A-Z])", "$1 $2")
									</th>
								}
							</tr>
						</thead>
						<tbody>
							@foreach(var accounts in Model.OverduePayments)
							{
								<tr>
									@foreach (PropertyInfo prop in properties)
									{
										var value = prop.GetValue(accounts);
										<td>
											@if (prop.Name == nameof(OverduePaymentsDTO.Id))
											{
												<span class="text-muted font-monospace">#@value</span>
											}
											else if (prop.Name == nameof(OverduePaymentsDTO.AmountOverdue))
											{
												<span class="text-danger fw-bold">@(((decimal)(value ?? 0m)).ToString("C"))</span>
											}
											else if (prop.Name == nameof(OverduePaymentsDTO.DaysPastDue))
											{
												var days = (int)(value ?? 0);
												<span class="badge @(days > 60 ? "bg-danger" : days > 30 ? "bg-warning text-dark" : "bg-secondary")">
													@days Days
												</span>
											}
											else if (prop.Name == nameof(OverduePaymentsDTO.Status))
											{
												var status = value?.ToString();
												<span class="badge rounded-pill bg-light text-dark border border-secondary px-2">@status</span>
											}
											else
											{
												@value
											}
										</td>
									}
								</tr>
							}
						</tbody>
					</table>
				</div>

				<script>
					document.getElementById("paymentsSearch").addEventListener("keyup", function ()
					{
						let filter = this.value.toLowerCase();
						let rows = document.querySelectorAll("#paymentsTable tbody tr");

						rows.forEach(row => 
						{
							let text = row.innerText.toLowerCase();
							row.style.display = text.includes(filter) ? "" : "none";
						});
					});
				</script>
			}
		</div>
	</div>
</div>