@page
@model ReportApp.Pages.Report_Pages.IndexModel
@{
	ViewData["Title"] = "Reports Management Portal";
}

<div class="container mt-4">
	<div class="p-5 mb-4 bg-light rounded-3 border">
		<div class="container-fluid py-2">
			<h1 class="display-5 fw-bold text-dark">Reports Management Portal</h1>
			<p class="col fs-5 text-muted">
				Welcome back, Property Manager. Select an operational domain control tile below to review real-time infrastructure logs, analytics, and asset health metrics.
			</p>
		</div>
	</div>

	<div class="row g-4 justify-content-center">
		<div class="col-md-6">
			<div class="card h-100 shadow-sm hover-shadow border-primary">
				<div class="card-body d-flex flex-column p-4">
					<div class="mb-3">
						<span class="badge bg-primary px-3 py-2">Infrastructure Asset Log</span>
					</div>
					<h3 class="card-title fw-bold text-dark">Overview Report</h3>
					<p class="card-text text-muted flex-grow-1">
						Review building occupancy breakdown, unit specifications, specs configurations, physical amenities, and recorded rental revenue streams.
					</p>
					<a href="/Report_Pages/Overview" class="btn btn-primary w-100 py-2 mt-3fw-bold">
						Open Overview &rarr;
					</a>
				</div>
			</div>
		</div>

		<div class="col-md-6">
			<div class="card h-100 shadow-sm hover-shadow border-primary">
				<div class="card-body d-flex flex-column p-4">
					<div class="mb-3">
						<span class="badge bg-primary px-3 py-2">Ticketing Velocity Analytics</span>
					</div>
					<h3 class="card-title fw-bold text-dark">Maintenance Requests Log</h3>
					<p class="card-text text-muted flex-grow-1">
						Track live outstanding task backlogs, categorize active issues by mechanical skill-profile, evaluate critical risks, and track ticket velocities.
					</p>
					<a href="/Report_Pages/MaintenanceRequest" class="btn btn-primary w-100 py-2 mt-3 fw-bold">
						Open Maintenance Viewer &rarr;
					</a>
				</div>
			</div>
		</div>

		<div class="col-md-6">
			<div class="card h-100 shadow-sm hover-shadow border-primary">
				<div class="card-body d-flex flex-column p-4">
					<div class="mb-3">
						<span class="badge bg-primary px-3 py-2">Collections & Accounts delinquency</span>
					</div>
					<h3 class="card-title fw-bold text-dark">Overdue Payment Summary</h3>
					<p class="card-text text-muted flex-grow-1">
						Monitor aging balances, view critial tenant arrears logs, and isolate historical past-due account categories.
					</p>
					<a href="/Report_Pages/OverduePayments" class="btn btn-primary w-100 py-2 mt-3fw-bold">
						Open Financial Tracking &rarr;
					</a>
				</div>
			</div>
		</div>

		<div class="col-md-6">
			<div class="card h-100 shadow-sm hover-shadow border-primary">
				<div class="card-body d-flex flex-column p-4">
					<div class="mb-3">
						<span class="badge bg-primary px-3 py-2">Asset Allocation Analytics</span>
					</div>
					<h3 class="card-title fw-bold text-dark">Occupancy Performance Rates</h3>
					<p class="card-text text-muted flex-grow-1">
						Evaluate high-level aggregated performance metrics across real estate blocks and analyze capacity ratios.
					</p>
					<a href="/Report_Pages/OccupancyAnalytics" class="btn btn-primary w-100 py-2 mt-3fw-bold">
						Open Metrics Dashboard &rarr;
					</a>
				</div>
			</div>
		</div>
	</div>
</div>