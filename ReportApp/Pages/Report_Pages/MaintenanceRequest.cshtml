@page
@model ReportApp.Pages.Report_Pages.MaintenanceRequestModel
@using System.Reflection
@{
	ViewData["Title"] = "Maintenance Requests Report";

	PropertyInfo[] properties = typeof(MaintenanceRequestDTO).GetProperties();
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
		<div>
			<h2 class="text-dark mb-1">Maintenance Request Lifecycle Report</h2>
			<p class="text-muted mb-0">Operational summry showing tracking backlogs and resolution velocities</p>
		</div>
		<a href="/Report_Pages/Index" class="btn btn-outline-secondary fw-bold px-3 py-2">&larr; Back to Portal</a>
	</div>

	<div class="card shadow-sm">
		<div class="card-header bg-dark py-3">
			<h5 class="mb-0 text-white">System Logs (@Model.MaintenanceRequests.Count Records)</h5>
		</div>
		<div class="card-body p-0">
			@if (Model.MaintenanceRequests == null || !Model.MaintenanceRequests.Any())
			{
				<div class="p-4 text-center text-muted">No data streams found for this reporting profile</div>
			}
			else
			{
				<input type="text" id="searchInput" placeholder="Search maintenance logs..." class="form-control mb-3 shadow-sm"/>

				<div class="table-responsive">
					<table class="table table-striped table-hover mb-0 align-middle" id="maintenanceRequest">
						<thead class="table-light">
							<tr>
								@foreach (PropertyInfo prop in properties)
								{
									<th>
										@System.Text.RegularExpressions.Regex.Replace(prop.Name, "([a-z])([A-Z])", "$1 $2")
									</th>
								}
							</tr>
						</thead>
						<tbody>
							@foreach (var item in Model.MaintenanceRequests)
							{
								<tr>
									@foreach (PropertyInfo prop in properties)
									{
										var value = prop.GetValue(item);

										<td>
											@if (prop.Name == "priority" || prop.Name == "status")
											{
												<span class="badge rounded-pill bg-light text-dark border border-secondary px-2">
													@(value ?? "N/A")
												</span>
											}
											else if (prop.Name == "Id")
											{
												<span class="text-muted font-monospace">#@value</span>
											}
											else
											{
												@value
											}
										</td>
									}
								</tr>
							}
						</tbody>
					</table>
				</div>

				<script>
					document.getElementById("searchInput").addEventListener("keyup", function ()
					{
						let filter = this.value.toLowerCase();
						let rows = document.querySelectorAll("#maintenanceRequest tbody tr");

						rows.forEach(row => {
							let text = row.innerText.toLowerCase();
							row.style.display = text.includes(filter) ? "" : "none";
						});
					});
				</script>
			}
		</div>
	</div>
</div>